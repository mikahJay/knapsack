# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit secrets.
# ─────────────────────────────────────────────────────────────

# Set to "true" in production; "false" for local / staging
IS_PROD=false

# Postgres
DATABASE_URL=postgres://knapsack:knapsack@localhost:5432/knapsack

# Express session
SESSION_SECRET=change-me-in-production

# Google OAuth (required when IS_PROD=true)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where the web frontend lives (used for OAuth redirect)
WEB_URL=http://localhost:3000
# Matcher service
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional: override the Claude model (default: claude-3-5-haiku-20241022)
CLAUDE_MODEL=
